<script>
// ═══════════════════════════════════════════
//  CONFIG
// ═══════════════════════════════════════════
const SIZE  = 3;
const CELL  = 68;   // px – must match CSS
const GAP   = 12;
const STEP  = CELL + GAP;  // 80
const HALF  = (SIZE - 1) / 2; // 1.0
const SCENE = 320;

// ═══════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════
let board    = []; // [z][y][x] → value
let tileGrid = []; // [z][y][x] → tileId | null
let tilePool = {}; // id → { el, gx, gy, gz, value }
let nextId   = 0;

let score = 0, best = 0, moveCount = 0;
let animating = false;
let hasWon = false; // tracks if win overlay already shown this game

// ═══════════════════════════════════════════
//  BOARD HELPERS
// ═══════════════════════════════════════════
function initArrays() {
  board    = Array.from({length:SIZE},()=>Array.from({length:SIZE},()=>Array(SIZE).fill(0)));
  tileGrid = Array.from({length:SIZE},()=>Array.from({length:SIZE},()=>Array(SIZE).fill(null)));
}
const at   = (x,y,z)   => board[z][y][x];
const setV = (x,y,z,v) => { board[z][y][x] = v; };

function addRandom() {
  const empty = [];
  for(let z=0;z<SIZE;z++) for(let y=0;y<SIZE;y++) for(let x=0;x<SIZE;x++)
    if(at(x,y,z)===0) empty.push({x,y,z});
  if(!empty.length) return false;
  const {x,y,z} = empty[Math.floor(Math.random()*empty.length)];
  const v = Math.random()<0.85?2:4;
  setV(x,y,z,v);
  tileGrid[z][y][x] = spawnTile(x,y,z,v);
  return true;
}

// ═══════════════════════════════════════════
//  SLIDE LOGIC
// ═══════════════════════════════════════════
// Returns array of move descriptors or null if nothing moved
function computeSlide(axis, sign) {
  // Deep-copy board & tileGrid for scratch
  const B  = board.map(l=>l.map(r=>[...r]));
  const TG = tileGrid.map(l=>l.map(r=>[...r]));
  const anims   = [];
  const merged  = new Set();

  // Map (a, b, c) where c is along the slide axis → {x,y,z}
  const toPos = (a,b,c) => {
    if(axis==='x') return {x:c, y:a, z:b};
    if(axis==='y') return {x:a, y:c, z:b};
    return                {x:a, y:b, z:c};
  };

  for(let a=0; a<SIZE; a++) {
    for(let b2=0; b2<SIZE; b2++) {
      // Multiple compaction passes
      for(let pass=0; pass<SIZE*2; pass++) {
        for(let ci=0; ci<SIZE-1; ci++) {
          // c is where we want to push things TO (destination end)
          const c  = sign===1 ? (SIZE-1-ci) : ci;
          const cn = sign===1 ? c-1          : c+1;
          if(cn<0||cn>=SIZE) continue;

          const dst = toPos(a,b2,c);
          const src = toPos(a,b2,cn);

          const dv = B[dst.z][dst.y][dst.x];
          const sv = B[src.z][src.y][src.x];
          const dt = TG[dst.z][dst.y][dst.x];
          const st = TG[src.z][src.y][src.x];
          const dk = `${dst.x},${dst.y},${dst.z}`;
          const sk = `${src.x},${src.y},${src.z}`;

          if(dv===0 && sv!==0) {
            // Slide into empty
            B[dst.z][dst.y][dst.x]  = sv;
            B[src.z][src.y][src.x]  = 0;
            TG[dst.z][dst.y][dst.x] = st;
            TG[src.z][src.y][src.x] = null;
            anims.push({ tileId:st, fx:src.x, fy:src.y, fz:src.z,
                                    tx:dst.x, ty:dst.y, tz:dst.z,
                         newVal:sv, isMerge:false });
          } else if(dv!==0 && dv===sv && dt!==null && st!==null &&
                    !merged.has(dk) && !merged.has(sk)) {
            // Merge
            const nv = dv*2;
            B[dst.z][dst.y][dst.x]  = nv;
            B[src.z][src.y][src.x]  = 0;
            TG[src.z][src.y][src.x] = null;
            // dt stays at dst; st moves to dst and disappears
            anims.push({ tileId:st, fx:src.x, fy:src.y, fz:src.z,
                                    tx:dst.x, ty:dst.y, tz:dst.z,
                         newVal:nv, isMerge:true, survivorId:dt });
            merged.add(dk);
          }
        }
      }
    }
  }

  // Check if anything actually changed
  let changed = false;
  outer: for(let z=0;z<SIZE;z++) for(let y=0;y<SIZE;y++) for(let x=0;x<SIZE;x++)
    if(B[z][y][x]!==board[z][y][x]||TG[z][y][x]!==tileGrid[z][y][x]){changed=true;break outer;}

  if(!changed) return null;

  // Commit scratch → live
  for(let z=0;z<SIZE;z++) for(let y=0;y<SIZE;y++) for(let x=0;x<SIZE;x++) {
    board[z][y][x]    = B[z][y][x];
    tileGrid[z][y][x] = TG[z][y][x];
  }
  return anims;
}

const DIRS = {
  right:{axis:'x',sign: 1}, left:{axis:'x',sign:-1},
  down: {axis:'y',sign: 1}, up:  {axis:'y',sign:-1},
  out:  {axis:'z',sign: 1}, in:  {axis:'z',sign:-1},
};

function hasMovesLeft() {
  for(let z=0;z<SIZE;z++) for(let y=0;y<SIZE;y++) for(let x=0;x<SIZE;x++) {
    if(at(x,y,z)===0) return true;
    if(x+1<SIZE && at(x,y,z)===at(x+1,y,z)) return true;
    if(y+1<SIZE && at(x,y,z)===at(x,y+1,z)) return true;
    if(z+1<SIZE && at(x,y,z)===at(x,y,z+1)) return true;
  }
  return false;
}

// ═══════════════════════════════════════════
//  3D CSS TILE RENDERING
// ═══════════════════════════════════════════
const root = document.getElementById('cube-root');

// Convert 3-D grid position → CSS translate3d values
// The scene div is SCENE×SCENE; origin is its centre
function worldPos(gx, gy, gz) {
  return {
    x: SCENE/2 + (gx - HALF) * STEP - CELL/2,
    y: SCENE/2 + (gy - HALF) * STEP - CELL/2,
    z: (gz - HALF) * STEP
  };
}

function applyTileTransform(el, gx, gy, gz, animate) {
  const {x,y,z} = worldPos(gx, gy, gz);
  el.style.transition = animate
    ? 'transform 0.28s cubic-bezier(0.25,0.46,0.45,0.94)'
    : 'none';
  // Store for merge-pop animation reference
  el.style.setProperty('--tx', x+'px');
  el.style.setProperty('--ty', y+'px');
  el.style.setProperty('--tz', z+'px');
  el.style.transform = `translate3d(${x}px,${y}px,${z}px)`;
}

function buildTileEl(value) {
  const el = document.createElement('div');
  el.className = 'tile v'+(value||0);
  ['front','back','right','left','top','bottom'].forEach(face => {
    const f = document.createElement('div');
    f.className = 'face '+face;
    if(value) {
      const sp = document.createElement('span');
      sp.className = 'val';
      sp.textContent = value;
      f.appendChild(sp);
    }
    el.appendChild(f);
  });
  return el;
}

function spawnTile(gx, gy, gz, value) {
  const id = nextId++;
  const el = buildTileEl(value);
  root.appendChild(el);
  applyTileTransform(el, gx, gy, gz, false);
  tilePool[id] = { el, gx, gy, gz, value };
  return id;
}

function moveTile(id, gx, gy, gz, animate) {
  const t = tilePool[id];
  if(!t) return;
  t.gx=gx; t.gy=gy; t.gz=gz;
  applyTileTransform(t.el, gx, gy, gz, animate);
}

function updateTileValue(id, value) {
  const t = tilePool[id];
  if(!t) return;
  t.value = value;
  t.el.className = 'tile v'+value;
  t.el.querySelectorAll('.val').forEach(s=>s.textContent=value);
}

function removeTile(id) {
  const t = tilePool[id];
  if(!t) return;
  t.el.remove();
  delete tilePool[id];
}

function buildCage() {
  // Ghost tiles as visual slot markers
  for(let z=0;z<SIZE;z++) for(let y=0;y<SIZE;y++) for(let x=0;x<SIZE;x++) {
    const el = buildTileEl(0);
    el.dataset.cage = 1;
    root.appendChild(el);
    applyTileTransform(el, x, y, z, false);
  }
}

// ═══════════════════════════════════════════
//  GAME FLOW
// ═══════════════════════════════════════════
function initGame() {
  root.innerHTML = '';
  tilePool = {}; nextId = 0;
  score = 0; moveCount = 0; hasWon = false;
  updateStats();
  initArrays();
  buildCage();
  addRandom(); addRandom();
}

function doMove(dirName) {
  if(animating) return;
  const dir = DIRS[dirName];
  if(!dir) return;

  const anims = computeSlide(dir.axis, dir.sign);
  if(!anims || anims.length===0) return; // nothing moved — keep animating=false

  animating = true;
  moveCount++;

  const ANIM = 280;

  // Deduplicate: if the same tileId appears multiple times (multi-step slides
  // emitted one record per step), keep only the last record for each tileId
  const animMap = new Map();
  anims.forEach(a => animMap.set(a.tileId, a));
  const dedupedAnims = Array.from(animMap.values());

  // Phase 1 – animate all tiles to their final positions
  dedupedAnims.forEach(a => moveTile(a.tileId, a.tx, a.ty, a.tz, true));

  // Phase 2 – after animation, resolve merges, spawn new tile
  setTimeout(()=>{
    dedupedAnims.forEach(a => {
      if(a.isMerge) {
        removeTile(a.tileId);
        updateTileValue(a.survivorId, a.newVal);
        const st = tilePool[a.survivorId];
        if(st) {
          st.el.classList.remove('merging');
          void st.el.offsetWidth;
          st.el.classList.add('merging');
        }
        score += a.newVal;
      }
    });

    if(score>best) best=score;
    updateStats();

    // Win check — only show once per game
    if(!hasWon) {
      for(let z=0;z<SIZE;z++) for(let y=0;y<SIZE;y++) for(let x=0;x<SIZE;x++)
        if(at(x,y,z)===2048) { hasWon=true; break; }
      if(hasWon) {
        addRandom(); // spawn one tile then pause for win message
        animating=false;
        showOverlay('YOU WIN! 🎉','You reached <span style="color:var(--accent)">2048</span>!\n\nKeep playing to beat your score, or start a new game.');
        return;
      }
    }

    addRandom();
    animating = false;

    if(!hasMovesLeft()) triggerGameOver();
  }, ANIM+30);
}

function updateStats() {
  document.getElementById('score').textContent = score;
  document.getElementById('best').textContent  = best;
  document.getElementById('moves').textContent = moveCount;
}

// ═══════════════════════════════════════════
//  GAME OVER CINEMATIC
// ═══════════════════════════════════════════
function triggerGameOver() {
  animating = true; // block input during cinematic

  const goScreen   = document.getElementById('go-screen');
  const goFlash    = document.getElementById('go-flash');
  const goShock    = document.getElementById('go-shockwave');
  const goShock2   = document.getElementById('go-shockwave2');
  const goSing     = document.getElementById('singularity');
  const goScoreEl  = document.getElementById('go-score-display');
  const goScoreVal = document.getElementById('go-score-val');

  goScreen.classList.add('active');
  goScoreVal.textContent = score;

  // ── Phase 1: Explosion (0ms) ──
  const allTiles = Object.values(tilePool);
  allTiles.forEach(t => {
    const ex = (Math.random() - 0.5) * 600;
    const ey = (Math.random() - 0.5) * 600;
    const ez = (Math.random() - 0.5) * 600;
    const rx = (Math.random() - 0.5) * 720;
    const ry = (Math.random() - 0.5) * 720;
    t.el.style.setProperty('--ex', ex + 'px');
    t.el.style.setProperty('--ey', ey + 'px');
    t.el.style.setProperty('--ez', ez + 'px');
    t.el.style.setProperty('--rx', rx + 'deg');
    t.el.style.setProperty('--ry', ry + 'deg');
    t.el.classList.add('exploding');
  });

  goFlash.classList.add('firing');
  setTimeout(() => { goShock.classList.add('firing'); }, 60);
  setTimeout(() => { goShock2.classList.add('firing'); }, 120);

  // ── Phase 2: Score flash (1600ms) ──
  setTimeout(() => {
    goScoreEl.classList.add('appear');
  }, 1600);

  // ── Phase 3: Collapse (2600ms) ──
  setTimeout(() => {
    allTiles.forEach(t => {
      t.el.classList.remove('exploding');
      const {x,y,z} = worldPos(t.gx, t.gy, t.gz);
      t.el.style.transition = 'none';
      t.el.style.transform = `translate3d(${x}px,${y}px,${z}px)`;
      void t.el.offsetWidth;
      t.el.classList.add('collapsing');
    });
    goScoreEl.classList.remove('appear');
    goScoreEl.classList.add('vanish');
    goSing.classList.add('firing');
  }, 2600);

  // ── Phase 4: Show Game Over overlay (4200ms) ──
  setTimeout(() => {
    // Clean up cinematic elements
    goScreen.classList.remove('active');
    goFlash.className = '';
    goShock.className = '';
    goShock2.className = '';
    goSing.className = '';
    goScoreEl.className = '';

    // Populate and show the game over overlay
    const isNewBest = (score > 0 && score >= best);
    document.getElementById('go-final-score').textContent = score;
    document.getElementById('go-best-score').textContent  = best;
    const newBestBadge = document.getElementById('go-new-best');
    newBestBadge.style.display = isNewBest ? 'inline-block' : 'none';

    document.getElementById('gameover-overlay').classList.add('show');
    // animating stays true — input blocked until player taps Play Again
  }, 4200);
}

// ═══════════════════════════════════════════
//  CAMERA — 4 fixed isometric presets
// ═══════════════════════════════════════════
//
//  Each camera has:
//    rx, ry   → CSS rotateX / rotateY angles (degrees)
//    name     → displayed in cam-bar
//    up/down/left/right/in/out → which board direction each button fires
//
//  The cube always looks the same tilt (-28° X); only Y rotates by ±90°.
//  That gives 4 unambiguous faces where every arrow literally matches
//  what you see: pressing ↑ sends tiles toward the top of the screen, etc.
//
//  Depth (into/out of screen) is always the Z-axis relative to the camera:
//    cam 0 (rotY=38):   into=z-, out=z+
//    cam 1 (rotY=128):  into=x+, out=x-  (camera now faces the right side)
//    cam 2 (rotY=218):  into=z+, out=z-
//    cam 3 (rotY=308):  into=x-, out=x+

const CAMERAS = [
  { name:'FRONT-LEFT',  rx:-28, ry: 38,  up:'up',  down:'down', left:'left',  right:'right', in:'in',    out:'out'   },
  { name:'FRONT-RIGHT', rx:-28, ry:128,  up:'up',  down:'down', left:'in',    right:'out',   in:'right',  out:'left'  },
  { name:'BACK-RIGHT',  rx:-28, ry:218,  up:'up',  down:'down', left:'right', right:'left',  in:'out',    out:'in'    },
  { name:'BACK-LEFT',   rx:-28, ry:308,  up:'up',  down:'down', left:'out',   right:'in',    in:'left',   out:'right' },
];

// Readable axis labels shown on buttons, keyed by board direction
const DIR_LABELS = {
  up:'up', down:'down', left:'left', right:'right',
  in:'deep', out:'near',
};

let camIdx = 0;
let camAnimId = null; // rAF for smooth camera transition

const cubeRoot  = document.getElementById('cube-root');

// Snap the cube to the current camera (no animation)
function applyCamSnap() {
  const c = CAMERAS[camIdx];
  cubeRoot.style.transition = 'none';
  cubeRoot.style.transform  = `rotateX(${c.rx}deg) rotateY(${c.ry}deg)`;
}

// Smoothly animate the cube to the current camera
function animateToCam(fromRx, fromRy, toRx, toRy, ms=380) {
  const start = performance.now();
  // Cancel any in-flight transition
  if(camAnimId) cancelAnimationFrame(camAnimId);
  cubeRoot.style.transition = 'none';

  function step(now) {
    const raw = (now - start) / ms;
    const t   = Math.min(raw, 1);
    // ease-out cubic
    const e   = 1 - Math.pow(1-t, 3);
    const rx  = fromRx + (toRx - fromRx) * e;
    const ry  = fromRy + (toRy - fromRy) * e;
    cubeRoot.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;
    if(t < 1) camAnimId = requestAnimationFrame(step);
    else camAnimId = null;
  }
  camAnimId = requestAnimationFrame(step);
}

function updateCamUI() {
  const c = CAMERAS[camIdx];

  // Dots
  document.querySelectorAll('.cam-dot').forEach((d,i) =>
    d.classList.toggle('active', i===camIdx));

  // Name + center cell
  document.getElementById('cam-name').textContent = c.name;
  document.getElementById('cam-num').textContent  = `${camIdx+1}/4`;

  // Axis labels on arrow buttons
  document.getElementById('ax-up').textContent    = DIR_LABELS[c.up]    || '';
  document.getElementById('ax-down').textContent  = DIR_LABELS[c.down]  || '';
  document.getElementById('ax-left').textContent  = DIR_LABELS[c.left]  || '';
  document.getElementById('ax-right').textContent = DIR_LABELS[c.right] || '';

  // Depth buttons
  document.getElementById('lbl-in').innerHTML  = `INTO<br>SCREEN`;
  document.getElementById('lbl-out').innerHTML = `OUT OF<br>SCREEN`;
}

function rotateCam(delta) {
  const prev = CAMERAS[camIdx];
  camIdx = (camIdx + delta + CAMERAS.length) % CAMERAS.length;
  const next = CAMERAS[camIdx];

  // Short-path angle: pick the direction that's ≤180°
  let fromRy = prev.ry;
  let toRy   = next.ry;
  let diff = ((toRy - fromRy) % 360 + 360) % 360;
  if(diff > 180) diff -= 360;
  animateToCam(prev.rx, fromRy, next.rx, fromRy + diff);
  updateCamUI();
}

// Wire cam dots
document.querySelectorAll('.cam-dot').forEach(d => {
  function go() {
    const target = parseInt(d.dataset.cam);
    if(target === camIdx) return;
    const delta = ((target - camIdx + 4) % 4 <= 2) ? (target - camIdx + 4) % 4 : -((camIdx - target + 4) % 4);
    rotateCam(delta);
  }
  d.addEventListener('touchstart', e=>{ e.preventDefault(); go(); }, {passive:false});
  d.addEventListener('click', e=>{ if(e.detail===0) return; go(); });
});

// Cycle button
function bindBtn(id, fn) {
  const el = document.getElementById(id);
  el.addEventListener('touchstart', e=>{ e.stopPropagation(); e.preventDefault(); fn(); }, {passive:false});
  el.addEventListener('click', e=>{ if(e.detail===0) return; e.stopPropagation(); fn(); });
}
bindBtn('btn-cam-rev', () => rotateCam(-1));
bindBtn('btn-cam',     () => rotateCam(1));

// ═══════════════════════════════════════════
//  CONTEXT-AWARE INPUT
// ═══════════════════════════════════════════
function fire(slot) {
  // slot is 'up','down','left','right','in','out'
  const dir = CAMERAS[camIdx][slot];
  if(dir) doMove(dir);
}

bindBtn('dp-up',    () => fire('up'));
bindBtn('dp-down',  () => fire('down'));
bindBtn('dp-left',  () => fire('left'));
bindBtn('dp-right', () => fire('right'));
bindBtn('btn-in',   () => fire('in'));
bindBtn('btn-out',  () => fire('out'));

// Swipe on the scene to change camera (left/right swipe only — up/down makes a move)
let swipeStart = null;
const sceneWrap = document.getElementById('scene-wrapper');
sceneWrap.addEventListener('touchstart', e => {
  if(e.target.closest('button,.dp')) return;
  swipeStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
}, {passive:true});
sceneWrap.addEventListener('touchend', e => {
  if(!swipeStart) return;
  const dx = e.changedTouches[0].clientX - swipeStart.x;
  const dy = e.changedTouches[0].clientY - swipeStart.y;
  swipeStart = null;
  if(Math.abs(dx) < 30 && Math.abs(dy) < 30) return; // tap, ignore
  if(Math.abs(dx) >= Math.abs(dy)) {
    // Horizontal swipe → rotate camera
    rotateCam(dx < 0 ? 1 : -1);
  }
  // Vertical swipe intentionally does nothing — keeps scene clean
}, {passive:true});

// Keyboard — always relative to current camera
document.addEventListener('keydown', e => {
  const slot = {
    ArrowUp:'up', ArrowDown:'down', ArrowLeft:'left', ArrowRight:'right',
    w:'up', s:'down', a:'left', d:'right',
    q:'in', e:'out',
    '[': () => rotateCam(-1),
    ']': () => rotateCam(1),
  }[e.key];
  if(!slot) return;
  e.preventDefault();
  if(typeof slot === 'function') slot();
  else fire(slot);
});

// ═══════════════════════════════════════════
//  UI / OVERLAY
// ═══════════════════════════════════════════
function showOverlay(title,msg){
  document.getElementById('overlay-title').textContent=title;
  document.getElementById('overlay-msg').innerHTML=msg.replace(/\n/g,'<br>');
  document.getElementById('overlay').classList.add('show');
}

document.getElementById('btn-close').addEventListener('click',()=>document.getElementById('overlay').classList.remove('show'));
document.getElementById('btn-new').addEventListener('click',()=>{document.getElementById('overlay').classList.remove('show');initGame();});

document.getElementById('btn-go-play').addEventListener('click', () => {
  document.getElementById('gameover-overlay').classList.remove('show');
  animating = false;
  const lastScore = parseInt(document.getElementById('go-final-score').textContent) || 0;
  const lastBest  = parseInt(document.getElementById('go-best-score').textContent) || 0;
  const scoreNote = lastScore > 0
    ? `\n\nLast game: <span style="color:var(--accent);font-weight:700">${lastScore.toLocaleString()}</span> &nbsp;·&nbsp; Best: <span style="color:rgba(255,210,20,0.9);font-weight:700">${lastBest.toLocaleString()}</span>`
    : '';
  showOverlay('CUBE³',
    'Swipe the board left/right to orbit to any face.\n\n'+
    'Arrows always match what you see — tiles slide in the direction of the arrow.\n\n'+
    '● / ○ push tiles into or out of the screen.\n\n'+
    'Reach <span style="color:var(--accent)">2048</span> to win!' + scoreNote);
});

document.getElementById('btn-help').addEventListener('click',()=>showOverlay('HOW TO PLAY',
  '🎲 Tiles fill a 3×3×3 cube — 27 slots across 3 layers.\n\n'+
  '✨ Matching tiles that collide merge and double in value.\n\n'+
  '🔄 Swipe the board or tap ⟳ VIEW to orbit — arrows always match your view.\n\n'+
  '● pushes tiles into the screen &nbsp;·&nbsp; ○ pulls them out.\n\n'+
  '⌨️ Keyboard: WASD / arrows · Q=in · E=out · [/] rotate view'));

// ═══════════════════════════════════════════
//  BOOT
// ═══════════════════════════════════════════
applyCamSnap();
updateCamUI();

showOverlay('CUBE³',
  'A 3D twist on 2048.\n\n'+
  'Swipe left/right on the board to orbit to any face.\n\n'+
  'Arrows always point the direction tiles will <span style="color:var(--accent)">actually move</span> on screen.\n\n'+
  '● / ○ push tiles into or out of the screen depth.\n\n'+
  'Reach <span style="color:var(--accent)">2048</span> to win!');

initGame();
</script>
