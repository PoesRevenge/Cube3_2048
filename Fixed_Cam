
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>CUBE³ — 3D 2048</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Orbitron:wght@400;700;900&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg: #050508;
  --panel: #0d0d18;
  --accent: #00ffcc;
  --accent2: #ff006e;
  --text: #e0e0ff;
  --dim: #3a3a5c;
  --glow: 0 0 20px #00ffcc66;
  --CELL: 68px;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Space Mono', monospace;
  height: 100dvh;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  touch-action: none;
  user-select: none;
}

body::before {
  content: '';
  position: fixed; inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 20% 10%, rgba(0,255,204,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 50% 30% at 80% 80%, rgba(255,0,110,0.05) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}

#header {
  position: relative; z-index: 10;
  text-align: center;
  padding: 14px 20px 0;
  width: 100%;
  flex-shrink: 0;
}

h1 {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.4rem, 5vw, 2.2rem);
  font-weight: 900;
  letter-spacing: 0.25em;
  color: var(--accent);
  text-shadow: var(--glow), 0 0 60px #00ffcc22;
  animation: hpulse 4s ease-in-out infinite;
}
@keyframes hpulse {
  0%,100% { text-shadow: var(--glow); }
  50% { text-shadow: 0 0 30px #00ffcc, 0 0 70px #00ffcc44; }
}

.subtitle {
  font-size: 0.55rem; letter-spacing: 0.3em;
  color: var(--dim); margin-top: 2px; text-transform: uppercase;
}

#stats {
  display: flex; gap: 12px; margin-top: 10px; justify-content: center;
}
.stat-box {
  background: var(--panel);
  border: 1px solid var(--dim);
  border-radius: 8px; padding: 6px 16px;
  text-align: center; min-width: 80px;
}
.stat-label { font-size: 0.5rem; letter-spacing: 0.2em; color: var(--dim); text-transform: uppercase; }
.stat-value { font-family: 'Orbitron', sans-serif; font-size: 1.1rem; color: var(--accent); font-weight: 700; }

#scene-wrapper {
  position: relative; z-index: 10;
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  width: 100%;
  min-height: 0;
}

#scene {
  perspective: 700px;
  perspective-origin: 50% 45%;
  width: 320px; height: 320px;
}

#cube-root {
  width: 320px; height: 320px;
  transform-style: preserve-3d;
  transform: rotateX(-28deg) rotateY(38deg);
  position: relative;
}

/* ── TILE: a real CSS 3D cube ── */
.tile {
  position: absolute;
  width: 68px; height: 68px;
  transform-style: preserve-3d;
}

.face {
  position: absolute;
  width: 68px; height: 68px;
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Orbitron', sans-serif; font-weight: 700;
  font-size: 0.82rem;
  backface-visibility: hidden;
  border: 1px solid rgba(255,255,255,0.1);
}

/* 6 faces of the 68px cube — translateZ by half the cell size = 34px */
.face.front  { transform: translateZ(34px); }
.face.back   { transform: rotateY(180deg) translateZ(34px); filter: brightness(0.45); }
.face.right  { transform: rotateY(90deg)  translateZ(34px); filter: brightness(0.75); }
.face.left   { transform: rotateY(-90deg) translateZ(34px); filter: brightness(0.65); }
.face.top    { transform: rotateX(90deg)  translateZ(34px); filter: brightness(0.88); }
.face.bottom { transform: rotateX(-90deg) translateZ(34px); filter: brightness(0.5); }

/* Values on all faces — side/back faces slightly smaller to fit the foreshortened area */
.val { text-shadow: 0 1px 4px rgba(0,0,0,0.7); pointer-events: none; line-height: 1; }
.face.front  .val { font-size: 0.82rem; }
.face.back   .val { font-size: 0.75rem; filter: brightness(2.2); }
.face.right  .val { font-size: 0.75rem; filter: brightness(1.4); }
.face.left   .val { font-size: 0.75rem; filter: brightness(1.6); }
.face.top    .val { font-size: 0.75rem; filter: brightness(1.2); }
.face.bottom .val { font-size: 0.75rem; filter: brightness(2.0); }

/* Empty slot — ghost cage cells */
.tile.v0 .face {
  background: rgba(14,14,32,0.35);
  border-color: rgba(58,58,92,0.18);
}

/* Tile value colors — CSS custom props applied per class */
.v2    .face { background: rgba(0,185,125,0.88);  color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v4    .face { background: rgba(10,210,110,0.9);  color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v8    .face { background: rgba(90,235,155,0.9);  color: #003318; box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v16   .face { background: rgba(255,210,20,0.9);  color: #1a1000; box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v32   .face { background: rgba(255,155,20,0.9);  color: #1a0800; box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v64   .face { background: rgba(255,80,20,0.9);   color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v128  .face { background: rgba(255,20,90,0.9);   color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v256  .face { background: rgba(190,20,255,0.9);  color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v512  .face { background: rgba(100,20,255,0.9);  color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v1024 .face { background: rgba(20,110,255,0.9);  color: #fff;    box-shadow: inset 0 0 8px rgba(0,0,0,0.25); }
.v2048 .face { background: linear-gradient(135deg,rgba(0,255,204,0.95),rgba(255,0,110,0.95)); color: #fff; }

/* Outer glow on front face only for non-empty tiles */
.v2 .face.front    { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 16px rgba(0,185,125,0.5); }
.v4 .face.front    { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 16px rgba(10,210,110,0.5); }
.v8 .face.front    { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 18px rgba(90,235,155,0.5); }
.v16 .face.front   { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 18px rgba(255,210,20,0.5); }
.v32 .face.front   { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 20px rgba(255,155,20,0.5); }
.v64 .face.front   { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 20px rgba(255,80,20,0.55); }
.v128 .face.front  { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 22px rgba(255,20,90,0.55); }
.v256 .face.front  { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 24px rgba(190,20,255,0.6); }
.v512 .face.front  { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 26px rgba(100,20,255,0.6); }
.v1024 .face.front { box-shadow: inset 0 0 8px rgba(0,0,0,0.2), 0 0 28px rgba(20,110,255,0.65); }
.v2048 .face.front { box-shadow: 0 0 40px rgba(0,255,204,0.8), 0 0 20px rgba(255,0,110,0.6); animation: winGlow 1.2s ease-in-out infinite alternate; }

@keyframes winGlow {
  from { box-shadow: 0 0 30px rgba(0,255,204,0.8); }
  to   { box-shadow: 0 0 60px rgba(255,0,110,0.9), 0 0 30px rgba(0,255,204,0.6); }
}

@keyframes mergePop {
  0%   { transform: scale(1) translate3d(var(--tx),var(--ty),var(--tz)); }
  45%  { transform: scale(1.4) translate3d(var(--tx),var(--ty),var(--tz)); }
  75%  { transform: scale(0.88) translate3d(var(--tx),var(--ty),var(--tz)); }
  100% { transform: scale(1) translate3d(var(--tx),var(--ty),var(--tz)); }
}
.tile.merging { animation: mergePop 0.36s ease forwards; }

/* ── CONTROLS ── */
#controls {
  position: relative; z-index: 10;
  width: 100%; flex-shrink: 0;
  padding: 6px 16px 12px;
  display: flex; flex-direction: column; align-items: center; gap: 7px;
}
.btn-row { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }

button {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 8px 14px; border-radius: 8px;
  border: 1px solid var(--dim);
  background: var(--panel); color: var(--text);
  cursor: pointer; transition: all 0.2s;
  -webkit-tap-highlight-color: transparent;
}
button:active, button:hover {
  border-color: var(--accent); color: var(--accent);
  box-shadow: 0 0 10px #00ffcc33;
}
button.primary { border-color: var(--accent); color: var(--accent); }

/* ── Camera indicator bar ── */
#cam-bar {
  display: flex; align-items: center; gap: 12px;
}
#cam-dots { display: flex; gap: 6px; }
.cam-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--dim); transition: all 0.35s;
  cursor: pointer; flex-shrink: 0;
}
.cam-dot.active {
  background: var(--accent);
  box-shadow: 0 0 8px rgba(0,255,204,0.8);
  transform: scale(1.35);
}
#cam-name {
  font-size: 0.48rem; letter-spacing: 0.2em; color: var(--dim);
  text-transform: uppercase; transition: color 0.3s; min-width: 70px;
}
#btn-cam {
  padding: 5px 10px; font-size: 0.52rem; letter-spacing: 0.06em;
  border-color: rgba(0,255,204,0.3); color: rgba(0,255,204,0.6);
}
#btn-cam:hover, #btn-cam:active {
  border-color: var(--accent); color: var(--accent);
}

/* ── Main control layout: [depth-in] [dpad] [depth-out] ── */
#ctrl-row {
  display: flex; align-items: center; gap: 10px;
}

/* Depth buttons on left/right of dpad */
.depth-btn-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 4px;
}
.depth-btn {
  width: 44px; height: 44px; padding: 0;
  font-size: 1.05rem;
  display: flex; align-items: center; justify-content: center;
  border-radius: 10px;
}
.depth-lbl {
  font-size: 0.36rem; letter-spacing: 0.08em; color: var(--dim);
  text-transform: uppercase; text-align: center; line-height: 1.4;
  pointer-events: none; max-width: 44px;
}

/* 3×3 d-pad grid */
#dpad {
  display: grid;
  grid-template-columns: repeat(3, 48px);
  grid-template-rows: repeat(3, 48px);
  gap: 4px;
}
.dp {
  width: 48px; height: 48px; padding: 0;
  font-size: 1.15rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 1px;
  border-radius: 10px;
}
.dp-empty {
  pointer-events: none;
  background: transparent !important;
  border-color: transparent !important;
  box-shadow: none !important;
}
/* Tiny axis label under the arrow */
.dp-axis {
  font-size: 0.35rem; letter-spacing: 0.05em; color: var(--dim);
  text-transform: uppercase; pointer-events: none; line-height: 1;
}
/* Center cell — shows cam number */
#dp-center {
  background: rgba(58,58,92,0.18);
  border: 1px solid rgba(58,58,92,0.35);
  border-radius: 10px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  font-size: 0.36rem; letter-spacing: 0.1em;
  color: var(--dim); text-transform: uppercase;
  line-height: 1.6; cursor: default;
}

/* ── GAME OVER CINEMATIC ── */
#go-screen {
  display: none; position: fixed; inset: 0;
  z-index: 300; pointer-events: none;
  align-items: center; justify-content: center;
}
#go-screen.active { display: flex; }

/* Full-screen flash on explosion */
#go-flash {
  position: fixed; inset: 0;
  background: white;
  opacity: 0; pointer-events: none;
  z-index: 310;
}
@keyframes goFlash {
  0%   { opacity: 0; }
  8%   { opacity: 0.85; }
  100% { opacity: 0; }
}
#go-flash.firing { animation: goFlash 0.6s ease-out forwards; }

/* Shockwave ring */
#go-shockwave {
  position: fixed;
  top: 50%; left: 50%;
  width: 10px; height: 10px;
  margin: -5px 0 0 -5px;
  border-radius: 50%;
  border: 3px solid rgba(0,255,204,0.9);
  opacity: 0;
  z-index: 309;
  pointer-events: none;
}
@keyframes goShockwave {
  0%   { transform: scale(1);   opacity: 0.9; }
  100% { transform: scale(80);  opacity: 0; }
}
#go-shockwave.firing { animation: goShockwave 0.8s cubic-bezier(0.2,0.6,0.4,1) forwards; }

/* Second slower ring */
#go-shockwave2 {
  position: fixed;
  top: 50%; left: 50%;
  width: 10px; height: 10px;
  margin: -5px 0 0 -5px;
  border-radius: 50%;
  border: 2px solid rgba(255,0,110,0.7);
  opacity: 0;
  z-index: 308;
  pointer-events: none;
}
@keyframes goShockwave2 {
  0%   { transform: scale(1);   opacity: 0.7; }
  100% { transform: scale(60);  opacity: 0; }
}
#go-shockwave2.firing { animation: goShockwave2 1.1s 0.15s cubic-bezier(0.2,0.6,0.4,1) forwards; }

/* The singularity black hole dot */
#singularity {
  position: fixed;
  top: 50%; left: 50%;
  width: 6px; height: 6px;
  margin: -3px 0 0 -3px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 0 0 rgba(0,255,204,0);
  opacity: 0;
  z-index: 311;
  pointer-events: none;
  transform: scale(0);
}
@keyframes singularityAppear {
  0%   { transform: scale(0);   opacity: 0;   box-shadow: 0 0 0 0 rgba(0,255,204,0); }
  30%  { transform: scale(8);   opacity: 1;   box-shadow: 0 0 30px 10px rgba(0,255,204,0.8); }
  65%  { transform: scale(5);   opacity: 1;   box-shadow: 0 0 50px 20px rgba(255,0,110,0.7); }
  85%  { transform: scale(2);   opacity: 0.8; box-shadow: 0 0 20px 8px rgba(100,0,255,0.6); }
  100% { transform: scale(0);   opacity: 0;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
}
#singularity.firing { animation: singularityAppear 1.8s 0.5s cubic-bezier(0.4,0,0.2,1) forwards; }

/* Score reveal text — mid-cinematic flash */
#go-score-display {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  opacity: 0;
  z-index: 320;
  pointer-events: none;
}
#go-score-display .go-label {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.6rem, 6vw, 2.4rem);
  font-weight: 900;
  color: var(--accent2);
  letter-spacing: 0.2em;
  text-shadow: 0 0 30px rgba(255,0,110,0.8);
}
#go-score-display .go-score {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(2rem, 8vw, 3.5rem);
  font-weight: 900;
  color: var(--accent);
  letter-spacing: 0.1em;
  text-shadow: 0 0 40px rgba(0,255,204,0.9);
  margin-top: 8px;
}
#go-score-display .go-sub {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: var(--dim);
  letter-spacing: 0.2em;
  margin-top: 12px;
}
@keyframes goScoreIn {
  0%   { opacity: 0; transform: translate(-50%,-50%) scale(0.4); filter: blur(12px); }
  60%  { opacity: 1; transform: translate(-50%,-50%) scale(1.05); filter: blur(0); }
  100% { opacity: 1; transform: translate(-50%,-50%) scale(1); filter: blur(0); }
}
@keyframes goScoreOut {
  0%   { opacity: 1; transform: translate(-50%,-50%) scale(1); }
  100% { opacity: 0; transform: translate(-50%,-50%) scale(0); filter: blur(20px); }
}
#go-score-display.appear { animation: goScoreIn 0.7s cubic-bezier(0.34,1.56,0.64,1) forwards; }
#go-score-display.vanish { animation: goScoreOut 0.5s ease-in forwards; }

/* Tile explosion — each tile gets inline --ex/ey/ez explosion vector */
@keyframes tileExplode {
  0%   { transform: translate3d(var(--tx),var(--ty),var(--tz)) scale(1);   opacity: 1; }
  25%  { transform: translate3d(
           calc(var(--tx) + var(--ex)*0.3),
           calc(var(--ty) + var(--ey)*0.3),
           calc(var(--tz) + var(--ez)*0.3)
         ) scale(1.2) rotateX(var(--rx)) rotateY(var(--ry)); opacity: 1; }
  70%  { transform: translate3d(
           calc(var(--tx) + var(--ex)),
           calc(var(--ty) + var(--ey)),
           calc(var(--tz) + var(--ez))
         ) scale(0.6) rotateX(calc(var(--rx)*2)) rotateY(calc(var(--ry)*2)); opacity: 0.6; }
  100% { transform: translate3d(
           calc(var(--tx) + var(--ex)*1.3),
           calc(var(--ty) + var(--ey)*1.3),
           calc(var(--tz) + var(--ez)*1.3)
         ) scale(0) rotateX(calc(var(--rx)*3)) rotateY(calc(var(--ry)*3)); opacity: 0; }
}

/* Tile collapse into singularity */
@keyframes tileCollapse {
  0%   { transform: translate3d(var(--tx),var(--ty),var(--tz)) scale(1); opacity: 1; }
  100% { transform: translate3d(0px, 0px, 0px) scale(0) rotateX(720deg) rotateY(720deg); opacity: 0; }
}

.tile.exploding {
  animation: tileExplode 0.7s cubic-bezier(0.4,0,1,1) forwards;
  transition: none !important;
}
.tile.collapsing {
  animation: tileCollapse 0.6s cubic-bezier(0.4,0,0.6,1) forwards;
  transition: none !important;
}

/* ── POST-SINGULARITY GAME OVER OVERLAY ── */
#gameover-overlay {
  display: none; position: fixed; inset: 0;
  z-index: 400;
  background: rgba(5,5,8,0.97);
  align-items: center; justify-content: center;
  flex-direction: column; gap: 0;
  text-align: center; padding: 40px 30px;
}
#gameover-overlay.show { display: flex; }

@keyframes goOverlayIn {
  0%   { opacity: 0; }
  100% { opacity: 1; }
}
#gameover-overlay.show { animation: goOverlayIn 0.8s ease forwards; }

.go-title-line {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(2rem, 8vw, 3rem);
  font-weight: 900;
  color: var(--accent2);
  letter-spacing: 0.25em;
  text-shadow: 0 0 40px rgba(255,0,110,0.9), 0 0 80px rgba(255,0,110,0.4);
  animation: goTitlePulse 2s ease-in-out infinite;
  margin-bottom: 32px;
}
@keyframes goTitlePulse {
  0%,100% { text-shadow: 0 0 30px rgba(255,0,110,0.8); }
  50%     { text-shadow: 0 0 60px rgba(255,0,110,1), 0 0 100px rgba(255,0,110,0.5); }
}

.go-score-block {
  display: flex; flex-direction: column; align-items: center;
  gap: 6px; margin-bottom: 16px;
  padding: 20px 36px;
  border: 1px solid rgba(0,255,204,0.2);
  border-radius: 12px;
  background: rgba(0,255,204,0.04);
  position: relative;
}
.go-score-block::before {
  content: '';
  position: absolute; inset: -1px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(0,255,204,0.15), rgba(255,0,110,0.1));
  z-index: -1;
}
.go-score-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.55rem; letter-spacing: 0.3em;
  color: var(--dim); text-transform: uppercase;
}
.go-score-num {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(2.4rem, 9vw, 4rem);
  font-weight: 900; color: var(--accent);
  letter-spacing: 0.05em;
  text-shadow: 0 0 30px rgba(0,255,204,0.7);
  line-height: 1;
}

.go-best-block {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 32px;
}
.go-best-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem; letter-spacing: 0.2em;
  color: var(--dim); text-transform: uppercase;
}
.go-best-num {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.1rem; font-weight: 700;
  color: rgba(255,210,20,0.9);
  text-shadow: 0 0 16px rgba(255,210,20,0.6);
  letter-spacing: 0.05em;
}
.go-best-crown { font-size: 1rem; }

.go-divider {
  width: 60px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--dim), transparent);
  margin-bottom: 28px;
}

.go-new-badge {
  display: inline-block;
  font-family: 'Space Mono', monospace;
  font-size: 0.5rem; letter-spacing: 0.2em;
  color: rgba(255,210,20,0.9);
  border: 1px solid rgba(255,210,20,0.4);
  padding: 3px 10px; border-radius: 4px;
  background: rgba(255,210,20,0.08);
  margin-bottom: 8px;
  text-transform: uppercase;
}

#overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(5,5,8,0.94);
  z-index: 200;
  align-items: center; justify-content: center;
  flex-direction: column; gap: 18px;
  text-align: center; padding: 40px 30px;
}
#overlay.show { display: flex; }
#overlay h2 {
  font-family: 'Orbitron', sans-serif; font-size: 1.8rem;
  color: var(--accent); text-shadow: var(--glow);
}
#overlay p { color: var(--dim); font-size: 0.72rem; line-height: 1.9; max-width: 300px; }
</style>
</head>
